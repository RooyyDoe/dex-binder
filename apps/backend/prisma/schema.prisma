generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Card {
  id            Int      @id @default(autoincrement())
  externalId    String?  @unique
  name          String
  setName       String
  number        String
  rarity        String?
  imageUrl      String?
  imageSmallUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([setName, number, name], name: "set_number_name_unique")
}
